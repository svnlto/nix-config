{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "enableAllProjectMcpServers": false,
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "caveman@caveman": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true,
    "gemini@gemini-plugin-cc": true,
    "n8n-mcp-skills@n8n-mcp-skills": true,
    "obsidian@obsidian-skills": true,
    "pup@datadog-pup": true,
    "superpowers@claude-plugins-official": true,
    "terragrunt-skill@jfr992": true
  },
  "env": {
    "CAVEMAN_DEFAULT_MODE": "off",
    "CLAUDE_CODE_TMUX_TRUECOLOR": "1"
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "repo": "JuliusBrussee/caveman",
        "source": "github"
      }
    },
    "claude-code-plugins": {
      "source": {
        "repo": "anthropics/claude-code",
        "source": "github"
      }
    },
    "datadog-pup": {
      "source": {
        "repo": "DataDog/pup",
        "source": "github"
      }
    },
    "gemini-plugin-cc": {
      "source": {
        "repo": "m-ghalib/gemini-plugin-cc",
        "source": "github"
      }
    },
    "jfr992": {
      "source": {
        "repo": "jfr992/terragrunt-skill",
        "source": "github"
      }
    },
    "karpathy-skills": {
      "source": {
        "repo": "forrestchang/andrej-karpathy-skills",
        "source": "github"
      }
    },
    "n8n-mcp-skills": {
      "source": {
        "repo": "czlonkowski/n8n-skills",
        "source": "github"
      }
    },
    "obsidian-skills": {
      "source": {
        "repo": "kepano/obsidian-skills",
        "source": "github"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754125509075
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "bash '/Users/hummes1/.claude/hooks/herdr-agent-state.sh' blocked",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash '/Users/hummes1/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash '/Users/hummes1/.claude/hooks/herdr-agent-state.sh' release",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/hummes1/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash '/Users/hummes1/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash '/Users/hummes1/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "model": "claude-opus-4-6[1m]",
  "outputStyle": "Concise",
  "preferredNotifChannel": "ghostty",
  "remoteControlAtStartup": false,
  "skipWebFetchPreflight": true,
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "type": "command"
  },
  "terminalProgressBarEnabled": true,
  "theme": "dark-ansi",
  "tui": "fullscreen",
  "voiceEnabled": false
}
