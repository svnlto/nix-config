{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CAVEMAN_DEFAULT_MODE": "off",
    "CLAUDE_CODE_TMUX_TRUECOLOR": "1",
    "MCP_TIMEOUT": "60000"
  },
  "includeCoAuthoredBy": false,
  "model": "claude-opus-4-8[1m]",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/hummes1/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path') && [ -n \"$f\" ] && pre-commit run --files \"$f\" 2>&1 || true",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f flake.nix ] && nix flake check 2>&1 | head -20 || true",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "caveman@caveman": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true,
    "gemini@gemini-plugin-cc": false,
    "n8n-mcp-skills@n8n-mcp-skills": true,
    "obsidian@obsidian-skills": true,
    "pup@datadog-pup": true,
    "superpowers@claude-plugins-official": true,
    "terragrunt-skill@jfr992": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "datadog-pup": {
      "source": {
        "source": "github",
        "repo": "DataDog/pup"
      }
    },
    "gemini-plugin-cc": {
      "source": {
        "source": "github",
        "repo": "m-ghalib/gemini-plugin-cc"
      }
    },
    "jfr992": {
      "source": {
        "source": "github",
        "repo": "jfr992/terragrunt-skill"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "n8n-mcp-skills": {
      "source": {
        "source": "github",
        "repo": "czlonkowski/n8n-skills"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    }
  },
  "outputStyle": "Concise",
  "skipWebFetchPreflight": true,
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "preferredNotifChannel": "ghostty",
  "terminalProgressBarEnabled": true,
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754125509075
  }
}
