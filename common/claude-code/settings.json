{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CAVEMAN_DEFAULT_MODE": "lite",
    "CLAUDE_CODE_TMUX_TRUECOLOR": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MCP_TIMEOUT": "60000"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(nix flake check:*)",
      "Bash(nix flake show:*)",
      "Bash(nix eval:*)",
      "Bash(nixfmt:*)",
      "Bash(statix:*)",
      "Bash(deadnix:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(jq:*)",
      "Read(//Users/svenlito/Documents/obsidian-vault/**)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(sudo rm:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.pem)"
    ],
    "additionalDirectories": [
      "/Users/svenlito/Documents/obsidian-vault"
    ]
  },
  "model": "claude-opus-4-8[1m]",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/herdr-agent-state.sh session",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-destructive.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path'); [ -n \"$f\" ] || exit 0; root=$(git -C \"$(dirname \"$f\")\" rev-parse --show-toplevel 2>/dev/null) || exit 0; [ -f \"$root/.pre-commit-config.yaml\" ] || exit 0; out=$(cd \"$root\" && pre-commit run --files \"$f\" 2>&1); [ $? -eq 0 ] && exit 0; echo \"$out\" >&2; exit 2",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f flake.nix ] && git status --porcelain 2>/dev/null | grep -qE '\\.nix$' && nix flake check 2>&1 | head -20 || true",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "context7@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "pup@datadog-pup": true,
    "superpowers@claude-plugins-official": true,
    "terragrunt-skill@jfr992": true,
    "agent-skills@msg-kaas-platform": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "datadog-pup": {
      "source": {
        "source": "github",
        "repo": "DataDog/pup"
      }
    },
    "jfr992": {
      "source": {
        "source": "github",
        "repo": "jfr992/terragrunt-skill"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "msg-kaas-platform": {
      "source": {
        "source": "directory",
        "path": "/Users/hummes1/projects/msg/agent-skills"
      }
    }
  },
  "outputStyle": "Concise",
  "skipWebFetchPreflight": true,
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "preferredNotifChannel": "ghostty",
  "fileCheckpointingEnabled": true,
  "terminalProgressBarEnabled": true,
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754125509075
  }
}
